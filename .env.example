# App
NEXT_PUBLIC_APP_NAME=FinancTracker
NODE_ENV=development
APP_URL=http://localhost:3000

# Mongo
MONGODB_URI=mongodb://admin:admin@localhost:27017/financ-tracker?authSource=admin

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=ft_token

#Email
RESEND_API_KEY=replace-with-your-resend-api-key
EMAIL_FROM=FinancTracker <no-reply@your-domain.com>
EMAIL_REPLY_TO=support@your-domain.com
EMAIL_TOKEN_SECRET=replace-with-a-long-random-secret-for-email-tokens
EMAIL_TOKEN_EXPIRES_IN=24h

# Comma-separated list of sysadmin emails (non-privacy stats dashboard access)
SYS_ADMIN_EMAILS=admin@example.com
